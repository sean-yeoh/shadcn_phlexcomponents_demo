<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-16 p-4">
  <%= render Demo.new(title: "Accordion") do %>
    <%= render Accordion.new(class: 'w-full') do |a| %>
      <%= a.item(value: "item-1") do %>
        <%= a.trigger do %>
          Is it accessible?
        <% end %>

        <%= a.content do %>
          Yes. It adheres to the WAI-ARIA design pattern.
        <% end %>
      <% end %>

      <%= a.item(value: "item-2") do %>
        <%= a.trigger do %>
          Is it styled?
        <% end %>

        <%= a.content do %>
          Yes. It comes with default styles that matches the other components' aesthetic.
        <% end %>
      <% end %>

      <%= a.item(value: "item-3") do %>
        <%= a.trigger do %>
          Is it animated?
        <% end %>

        <%= a.content do %>
          Yes. It's animated.
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Alert Dialog") do %>
    <%= render AlertDialog.new do |a| %>
      <%= a.trigger do %>
        <%= render Button.new(variant: :outline) { "Open" } %>
      <% end %>

      <%= a.content do %>
        <%= a.header do %>
          <%= a.title { "Are you absolutely sure?" } %>
          <%= a.description { "This action cannot be undone. This will permanently delete your account and remove your data from our servers." } %>
        <% end %>

        <%= a.footer do %>
          <%= a.cancel { "Cancel" } %>
          <%= a.action(data: { show_alert: true }) { "Continue" } %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Alert") do %>
    <%= render Alert.new do |a| %>
      <%= lucide_icon("circle-check") %>
      <%= a.title { "Success! Your changes have been saved" } %>
      <%= a.description { "This is an alert with icon, title and description." } %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Aspect Ratio") do %>
    <%= render AspectRatio.new(ratio: "16/9") do %>
      <img class="h-full w-full rounded-md object-cover" src="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=800&dpr=2&q=80"  alt="Photo by Drew Beamer"/>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Avatar") do %>
    <%= render Avatar.new do |a| %>
      <%= a.image(src: "https://github.com/shadcn.png") %>
      <%= a.fallback { "CN" }%>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Badge") do %>
    <%= render Badge.new { "Default" } %>
  <% end %>

  <%= render Demo.new(title: "Breadcrumb") do %>
    <%= render Breadcrumb.new do |breadcrumb| %>
      <%= breadcrumb.item do %>
        <%= breadcrumb.link("Home", "#") %>
      <% end %>

      <%= breadcrumb.separator %>

      <%= breadcrumb.item do %>
        <%= breadcrumb.link("Users", "#") %>
      <% end %>

      <%= breadcrumb.separator %>

      <%= breadcrumb.item do %>
        <%= breadcrumb.page { "User #1" } %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Button") do %>
    <%= render Button.new { "Default" } %>

  <% end %>

  <%= render Demo.new(title: "Card") do %>
    <%= render Card.new(class: "w-[350px]") do |card| %>
      <%= card.header do %>
        <%= card.title { "Create project" } %>
        <%= card.description { "Deploy your new project in one-click." } %>
        <%= card.action do %>
          <%= render Button.new(variant: :link) { "Sign up" } %>
        <% end %>
      <% end %>

      <%= card.content do %>
        <form>
          <div class="grid w-full items-center gap-4">
            <div class="flex flex-col space-y-1.5">
              <%= render Label.new(for: "name") { "Name" } %>
              <%= render Input.new(id: "name", placeholder: "Name of your project") %>
            </div>
            <div class="flex flex-col space-y-1.5">
              <%= render Label.new(for: "description") { "Description" } %>
              <%= render Input.new(id: "description", placeholder: "Description of your project") %>
            </div>
          </div>
        </form>
      <% end %>

      <%= card.footer(class: "flex justify-between") do %>
        <%= render Button.new(variant: :outline) { "Cancel" } %>
        <%= render Button.new { "Create" } %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Checkbox Group") do %>
    <% fruits = [
      { name: "Apple", value: "apple" },
      { name: "Banana", value: "banana" },
      { name: "Blueberry", value: "blueberry" },
      { name: "Grapes", value: "grapes" },
      { name: "Pineapple", value: "pineapple" }
    ] %>

    <%= render CheckboxGroup.new(name: "fruits") do |c| %>
      <% c.items(fruits, text_method: :name, value_method: :value)  %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Checkbox") do %>
    <div class="items-top flex space-x-2">
      <%= render Checkbox.new(name: "terms1", id: "terms1") %>

      <div class="grid gap-1.5 leading-none">
        <%= render Label.new(for: "terms1") { "Accept terms and conditions" } %>
        <p class="text-sm text-muted-foreground">
          You agree to our Terms of Service and Privacy Policy.
        </p>
      </div>
    </div>
  <% end %>

  <%= render Demo.new(title: "Collapsible") do %>
    <%= render Collapsible.new(class: 'w-[350px] space-y-2') do |c| %>
      <div class="flex items-center justify-between space-x-4 px-4">
        <h4 class="text-sm font-semibold">
          @peduarte starred 3 repositories
        </h4>
        <%= c.trigger(as_child: true) do %>
          <%= render Button.new(variant: :ghost, size: :sm) do %>
            <%= lucide_icon("chevrons-up-down", class: "size-4") %>
          <% end %>
        <% end %>
      </div>
      <div class="rounded-md border px-4 py-2 font-mono text-sm shadow-sm">
        @radix-ui/primitives
      </div>
      <%= c.content(class: "space-y-2") do %>
        <div class="rounded-md border px-4 py-2 font-mono text-sm shadow-sm">
          @radix-ui/colors
        </div>
        <div class="rounded-md border px-4 py-2 font-mono text-sm shadow-sm">
          @stitches/react
        </div>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Combobox") do %>
    <%= render Combobox.new(class: "max-w-sm") do |c| %>
      <%= c.trigger %>

      <%= c.content do %>
        <%= c.group do %>
          <%= c.label { "Fruits" } %>
          <%= c.item(value: "apple") { "Apple" }%>
          <%= c.item(value: "banana") { "Banana" }%>
          <%= c.item(value: "blueberry") { "Blueberry" }%>
          <%= c.item(value: "grapes") { "Grapes" }%>
          <%= c.item(value: "pineapple") { "Pineapple" }%>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Command") do %>
    <%= render Command.new(shortcut_key: "/", class: "mr-4 hidden md:inline-flex") do |c| %>
      <%= c.trigger do %>
        <span class="hidden lg:inline-flex">Search documentation...</span>
        <span class="inline-flex lg:hidden">Search...</span>
      <% end %>

      <%= c.content do %>
        <%= c.group do %>
          <%= c.label { "Get Started" } %>
          <%= c.item(value: root_path) do %>
            <%= lucide_icon("file") %>
            Home
          <% end %>

          <%= c.item(value: root_path) do %>
            <%= lucide_icon("file") %>
            Docs
          <% end %>

          <%= c.item(value: root_path) do %>
            <%= lucide_icon("file") %>
            Components
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Date Picker") do %>
    <%= render DatePicker.new(class: "max-w-sm") %>
  <% end %>

  <%= render Demo.new(title: "Date Range Picker") do %>
    <%= render DateRangePicker.new(class: "max-w-sm") %>
  <% end %>

  <%= render Demo.new(title: "Dialog") do %>
    <%= render Dialog.new do |d| %>
      <%= d.trigger do %>
        <%= render Button.new(variant: :outline) { "Open" } %>
      <% end %>

      <%= d.content(class: "sm:max-w-[425px]") do %>
        <%= d.header do %>
          <%= d.title { "Edit profile" } %>
          <%= d.description { "Make changes to your profile here. Click save when you're done." } %>
        <% end %>

        <div class="grid gap-4 py-4">
          <div class="grid grid-cols-4 items-center gap-4">
            <%= render Label.new(for: "name") { "Name" } %>
            <%= render Input.new(id: "name", name: "name", value: "Pedro Duarte", class: "col-span-3") %>
          </div>

          <div class="grid grid-cols-4 items-center gap-4">
            <%= render Label.new(for: "username") { "Username" } %>
            <%= render Input.new(id: "username", name: "username", value: "@peduarte", class: "col-span-3") %>
          </div>
        </div>

        <%= d.footer do %>
          <%= render Button.new { "Save changes" } %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Dropdown Menu") do %>
    <%= render DropdownMenu.new do |d| %>
      <%= d.trigger do %>
        <%= render Button.new(variant: :outline) do   %>
          Open
        <% end %>
      <% end %>

      <%= d.content(class: 'w-56') do %>
        <%= d.label { "My Account" } %>
        <%= d.separator %>
        <%= d.item do %>
          Profile
        <% end %>

        <%= d.sub do |submenu| %>
          <%= submenu.trigger { "Invite users" } %>

          <%= submenu.content do %>
            <%= d.item do %>
              Email
            <% end %>

            <%= d.item do %>
              Message
            <% end %>

            <%= d.sub do |submenu| %>
              <%= submenu.trigger { "More" } %>

              <%= submenu.content do %>
                <%= d.item do %>
                  WhatsApp
                <% end %>

                <%= d.item do %>
                  Call
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>

        <%= d.separator %>

        <%= d.group do %>

          <%= d.item do %>
            Account
          <% end %>

          <%= d.item do %>
            Billing
          <% end %>

          <%= d.item do %>
            Settings
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Form") do %>
    <%= render Form.new(model: Book.new, url: form_path, class: "space-y-6") do |f| %>
      <%= f.input(:title) %>
      <%= f.submit %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Hover Card") do %>
    <%= render HoverCard.new do |h| %>
      <%= h.trigger(as_child: true) do %>
        <%= render Button.new(variant: :link) { "@rails" } %>
      <% end %>

      <%= h.content(class: "w-80") do %>
        <div class="flex space-x-4">
          <%= render Avatar.new do |a| %>
            <%= a.image(src: "https://github.com/rails.png") %>
          <% end %>

          <div class="space-y-1">
            <h4 class="text-sm font-semibold">@rails</h4>
            <p class="text-sm">
              The Ruby on Rails Framework
            </p>
            <div class="flex items-center pt-2">
              <%= lucide_icon("calendar", class: "mr-2 h-4 w-4 opacity-70") %>

              <span class="text-xs text-muted-foreground">
                Joined December 2021
              </span>
            </div>
          </div>
        <% end%>
      </div>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Input") do %>
    <%= render Input.new(class: "max-w-sm") %>
  <% end %>

  <%= render Demo.new(title: "Label") do %>
    <%= render Label.new { "Email" } %>
  <% end %>

  <%= render Demo.new(title: "Link") do %>
    <%= render Link.new("Link", "#") %>
  <% end %>

  <%= render Demo.new(title: "Loading Button") do %>
    <%= form_with url: form_path, method: :post, class: "group" do |f| %>
      <%= render LoadingButton.new { "Save" } %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Pagination") do %>
    <%= render Pagination.new do |p| %>
      <%= p.item do %>
        <%= p.previous("#") %>
      <% end %>

      <%= p.item do %>
        <%= p.link("#") { "1" } %>
      <% end %>

      <%= p.item do %>
        <%= p.link("#", active: true) { "2" } %>
      <% end %>

      <%= p.item do %>
        <%= p.link("#") { "3" } %>
      <% end %>

      <%= p.item do %>
        <%= p.ellipsis %>
      <% end %>

      <%= p.item do %>
        <%= p.next("#") %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Popover") do %>
    <%= render Popover.new do |p| %>
      <%= p.trigger(as_child: true) do %>
        <%= render Button.new(variant: :outline) { "Open popover" } %>
      <% end %>

      <%= p.content(class: "w-80") do %>
        <div class="grid gap-4">
          <div class="space-y-2">
            <h4 class="font-medium leading-none">Dimensions</h4>
            <p class="text-sm text-muted-foreground">
              Set the dimensions for the layer.
            </p>
          </div>
          <div class="grid gap-2">
            <div class="grid grid-cols-3 items-center gap-4">
              <%= render Label.new(for: "width") { "Width" } %>
              <%= render Input.new(name: "width", value: "100%", class: "col-span-2 h-8") %>
            </div>
            <div class="grid grid-cols-3 items-center gap-4">
              <%= render Label.new(for: "maxwidth") { "Max. width" } %>
              <%= render Input.new(name: "maxwidth", value: "300px", class: "col-span-2 h-8") %>
            </div>
            <div class="grid grid-cols-3 items-center gap-4">
              <%= render Label.new(for: "height") { "Height" } %>
              <%= render Input.new(name: "height", value: "25px", class: "col-span-2 h-8") %>
            </div>
            <div class="grid grid-cols-3 items-center gap-4">
              <%= render Label.new(for: "maxheight") { "Max. Height" } %>
              <%= render Input.new(name: "maxheight", value: "none", class: "col-span-2 h-8") %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Progress") do %>
    <%= render Progress.new(class: "w-[60%]") %>
  <% end %>

  <%= render Demo.new(title: "Radio Group") do %>
    <%= render RadioGroup.new(name: "preference") do |r| %>
      <div class="flex items-center space-x-2">
        <%= r.item(value: "default", id: "default1") %>
        <%= render Label.new(for: "default1") { "Default" } %>
      </div>

      <div class="flex items-center space-x-2">
        <%= r.item(value: "comfortable", id: "comfortable1") %>
        <%= render Label.new(for: "comfortable1") { "Comfortable" } %>
      </div>

      <div class="flex items-center space-x-2">
        <%= r.item(value: "compact", id: "compact1") %>
        <%= render Label.new(for: "compact1") { "Compact" } %>
      </div>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Select") do %>
    <%= render Select.new(class: "w-[180px]") do |s| %>
      <%= s.trigger %>

      <%= s.content do %>
        <%= s.group do %>
          <%= s.label { "Fruits" } %>
          <%= s.item(value: "apple") { "Apple" } %>
          <%= s.item(value: "banana") { "Banana" } %>
          <%= s.item(value: "blueberry") { "Blueberry" }%>
          <%= s.item(value: "grapes") { "Grapes" }%>
          <%= s.item(value: "pineapple") { "Pineapple" }%>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Separator") do %>
    <div>
      <div class="space-y-1">
        <h4 class="text-sm font-medium leading-none">Radix Primitives</h4>
        <p class="text-sm text-muted-foreground">
          An open-source UI component library.
        </p>
      </div>
      <%= render Separator.new(class: "my-4") %>
      <div class="flex h-5 items-center space-x-4 text-sm">
        <div>Blog</div>
        <%= render Separator.new(orientation: :vertical) %>
        <div>Docs</div>
        <%= render Separator.new(orientation: :vertical) %>
        <div>Source</div>
      </div>
    </div>
  <% end %>

  <%= render Demo.new(title: "Sheet") do %>
    <%= render Sheet.new do |s| %>
      <%= s.trigger do %>
        <%= render Button.new(variant: :outline) { "Open" } %>
      <% end %>

      <%= s.content(class: "sm:max-w-[425px]") do %>
        <%= s.header do %>
          <%= s.title { "Edit profile" } %>
          <%= s.description { "Make changes to your profile here. Click save when you're done." } %>
        <% end %>

        <div class="grid flex-1 auto-rows-min gap-6 px-4">
          <div class="grid gap-3">
            <%= render Label.new(for: "name") { "Name" } %>
            <%= render Input.new(id: "name", value: "Pedro Duarte") %>
          </div>
          <div class="grid gap-3">
            <%= render Label.new(for: "username") { "Username" } %>
            <%= render Input.new(id: "username", value: "@peduarte") %>
          </div>
        </div>

        <%= s.footer do %>
          <%= render Button.new { "Save changes" } %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Skeleton") do %>
    <div class="flex items-center space-x-4">
      <%= render Skeleton.new(class: "h-12 w-12 rounded-full") %>
      <div class="space-y-2">
        <%= render Skeleton.new(class: "h-4 w-[250px]") %>
        <%= render Skeleton.new(class: "h-4 w-[250px]") %>
      </div>
    </div>

  <% end %>

  <%= render Demo.new(title: "Slider") do %>
    <%= render Slider.new(class: 'w-xs') %>
  <% end %>

  <%= render Demo.new(title: "Switch") do %>
    <%= render Switch.new %>
  <% end %>

  <%= render Demo.new(title: "Table") do %>
    <% invoices = [
      {
        invoice: "INV001",
        paymentStatus: "Paid",
        totalAmount: "$250.00",
        paymentMethod: "Credit Card",
      },
      {
        invoice: "INV002",
        paymentStatus: "Pending",
        totalAmount: "$150.00",
        paymentMethod: "PayPal",
      },
      {
        invoice: "INV003",
        paymentStatus: "Unpaid",
        totalAmount: "$350.00",
        paymentMethod: "Bank Transfer",
      },
      {
        invoice: "INV004",
        paymentStatus: "Paid",
        totalAmount: "$450.00",
        paymentMethod: "Credit Card",
      },
      {
        invoice: "INV005",
        paymentStatus: "Paid",
        totalAmount: "$550.00",
        paymentMethod: "PayPal",
      },
      {
        invoice: "INV006",
        paymentStatus: "Pending",
        totalAmount: "$200.00",
        paymentMethod: "Bank Transfer",
      },
      {
        invoice: "INV007",
        paymentStatus: "Unpaid",
        totalAmount: "$300.00",
        paymentMethod: "Credit Card",
      },
    ] %>

    <%= render Table.new do |t| %>
      <%= t.caption { "A list of your recent invoices." } %>
      <%= t.header do %>
        <%= t.row do %>
          <%= t.head(class: "w-[100px]") { "Invoice" } %>
          <%= t.head { "Status" } %>
          <%= t.head { "Method" } %>
          <%= t.head(class: "text-right") { "Amount" } %>
        <% end %>
      <% end %>

      <%= t.body do %>
        <% invoices.each do |i| %>
          <%= t.row do %>
            <%= t.cell(class: "font-semibold") { i[:invoice] } %>
            <%= t.cell { i[:paymentStatus] } %>
            <%= t.cell { i[:paymentMethod] } %>
            <%= t.cell(class: "text-right") { i[:totalAmount] } %>
          <% end %>
        <% end %>
      <% end %>

      <%= t.footer do %>
        <%= t.row do %>
          <%= t.cell(colspan: 3) { "Total" } %>
          <%= t.cell(class: "text-right") { "$2,500.00" } %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Tabs") do %>
    <%= render Tabs.new(class: "w-[400px]") do |t| %>
      <%= t.list do %>
        <%= t.trigger(value: "account") { "Account" } %>
        <%= t.trigger(value: "password") { "Password" } %>
      <% end %>

      <%= t.content(value: "account") do %>
        <%= render Card.new do |c| %>
          <%= c.header do %>
            <%= c.title { "Account" } %>
            <%= c.description { "Make changes to your account here. Click save when you're done." } %>
          <% end %>

          <%= c.content(class: "space-y-2") do %>
            <div class="space-y-2">
              <%= render Label.new(for: "name")  { "Name" } %>
              <%= render Input.new(id: "name") %>
            </div>

            <div class="space-y-2">
              <%= render Label.new(for: "username") { "Username" } %>
              <%= render Input.new(id: "username") %>
            </div>
          <% end %>

          <%= c.footer do %>
            <%= render Button.new { "Save changes" } %>
          <% end %>
        <% end %>
      <% end %>

      <%= t.content(value: "password") do %>
        <%= render Card.new do |c| %>
          <%= c.header do %>
            <%= c.title { "Password" } %>
            <%= c.description { "Change your password here. After saving, you'll be logged out." } %>
          <% end %>

          <%= c.content(class: "space-y-2") do %>
            <div class="space-y-2">
              <%= render Label.new(for: "current") { "Current password" } %>
              <%= render Input.new(id: "current", type: "password") %>
            </div>

            <div class="space-y-2">
              <%= render Label.new(for: "new") { "New password" } %>
              <%= render Input.new(id: "new", type: "password") %>
            </div>
          <% end %>

          <%= c.footer do %>
            <%= render Button.new { "Save password" } %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Textarea") do %>
    <%= render Textarea.new %>
  <% end %>

  <%= render Demo.new(title: "Theme Switcher") do %>
    <%= render ThemeSwitcher.new %>
  <% end %>

  <%= render Demo.new(title: "Toast") do %>
    <%= render Toast.new(duration: 0, class: "mx-auto") do |t| %>
      <%= t.content do %>
        <%= t.title { "Uh oh! Something went wrong." }%>
        <%= t.description { "There was a problem with your request." }%>
      <% end %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Toggle") do %>
    <%= render Toggle.new do %>
      <%= lucide_icon("bold") %>
    <% end %>
  <% end %>

  <%= render Demo.new(title: "Tooltip") do %>
    <%= render Tooltip.new do |h| %>
      <%= h.trigger(as_child: true) do %>
        <%= render Button.new(variant: :outline) { "Hover" } %>
      <% end %>

      <%= h.content do %>
        Add to library
      <% end%>
    <% end %>
  <% end %>
</div>